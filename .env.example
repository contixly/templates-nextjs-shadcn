# Database
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://..."

# Better Auth Authentication
# Core Better Auth and application URL settings.
BETTER_AUTH_SECRET="..."
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# Optional OAuth provider credentials.
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# Public application defaults and analytics identifiers.
PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_YM_COUNTER_ID="12345678"

# Local-only automation and session-cache behavior.
LOCAL_AUTOMATION_AUTH_ENABLED=true
AUTH_DISABLE_SESSION_COOKIE_CACHE=false

# Caching
# Redis or Valkey-backed remote cache configuration.
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="password"
REMOTE_CACHING_ENABLED=false
REMOTE_CACHING_PREFIX="nextjs_template"
